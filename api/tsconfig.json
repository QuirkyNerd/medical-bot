{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["../web/*"]
    },
    "types": ["node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["next-env.d.ts", "**/*.ts"]
}
